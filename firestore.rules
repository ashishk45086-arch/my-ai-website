rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Default rule: reject anything not explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles & details
    match /users/{userId} {
      allow read: if isOwner(userId) || isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;

      match /favorites/{propertyId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }

      match /visits/{visitId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }
    }

    // Admins list
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.auth.uid == userId && (
          request.auth.token.email == 'admin@pgphagwara.com' || 
          request.auth.token.email == 'manager@pgphagwara.com' ||
          request.auth.token.email == 'blackhorse123@gmail.com'
        )
      ) || isAdmin();
      allow update, delete: if isSignedIn() && isAdmin();
    }

    // Properties list
    match /properties/{propertyId} {
      allow read: if true;
      allow write: if isSignedIn() && (
        isAdmin() || 
        request.auth.token.email == 'admin@pgphagwara.com' || 
        request.auth.token.email == 'manager@pgphagwara.com' ||
        request.auth.token.email == 'blackhorse123@gmail.com'
      );
    }

    // Rooms list
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isSignedIn() && (
        isAdmin() || 
        request.auth.token.email == 'admin@pgphagwara.com' || 
        request.auth.token.email == 'manager@pgphagwara.com' ||
        request.auth.token.email == 'blackhorse123@gmail.com'
      );
    }

    // Bookings collection
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isSignedIn() && (
        isAdmin() || 
        request.auth.token.email == 'admin@pgphagwara.com' || 
        request.auth.token.email == 'manager@pgphagwara.com' ||
        request.auth.token.email == 'blackhorse123@gmail.com'
      );
    }

    // Inquiries collection
    match /inquiries/{inquiryId} {
      allow read, update, delete: if isSignedIn() && (
        isAdmin() || 
        request.auth.token.email == 'admin@pgphagwara.com' || 
        request.auth.token.email == 'manager@pgphagwara.com' ||
        request.auth.token.email == 'blackhorse123@gmail.com'
      );
      allow create: if true;
    }

    // Notifications collection
    match /notifications/{notiId} {
      allow read, update, delete: if isSignedIn() && (
        isAdmin() || 
        request.auth.token.email == 'admin@pgphagwara.com' || 
        request.auth.token.email == 'manager@pgphagwara.com' ||
        request.auth.token.email == 'blackhorse123@gmail.com'
      );
      allow create: if true;
    }
  }
}
